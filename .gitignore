# Runtime + personal state (database, entity identity, your profile, history) — never tracked.
# Files are canonical per-project; this dir is local/personal and regenerated by `omni init`.
/state/*
!/state/.gitkeep

# Per-project working state is local runtime, created as you use the system.
/projects/*
!/projects/.gitkeep

# Worktree sandboxes (isolated git repos) must never be tracked by the root repo.
**/.worktrees/

# Node
node_modules/
npm-debug.log*

# OS
.DS_Store

# Secrets
.env
.env.*
!.env.example
